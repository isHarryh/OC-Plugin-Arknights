{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "oc-plugin-arknights",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isHarryh/OC-Plugin-Arknights.git"
  },
  "exports": {
    "./server": {
      "import": "./server.ts",
      "config": {
        "enabled": true
      }
    },
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "logo": {
          "enabled": true,
          "mode": "random",
          "selected": "rhodes"
        },
        "sound_pack": {
          "enabled": true,
          "override": true
        }
      }
    }
  },
  "engines": {
    "opencode": ">=1.14.48"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "sharp": "^0.35.3"
  }
}
